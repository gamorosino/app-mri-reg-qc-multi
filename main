#!/bin/bash
#PBS -l nodes=1:ppn=1,vmem=8g,walltime=6:00:00
#PBS -N app-mri-registration-qc-multiple
#PBS -V

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONTAINER_IMAGE="docker://gamorosino/tract_align:v1.0"

run_in_env() {
    singularity exec -e \
        "${CONTAINER_IMAGE}" \
        micromamba run -n tract_align "$@"
}

# ---------------------------------------------------------------------------
# Read parameters from config.json
# ---------------------------------------------------------------------------
mapfile -t IMAGES < <(jq -r '.images[]' config.json 2>/dev/null)

tiles=$(jq -r '.checkerboard_tiles // 8' config.json)
thr_mask=$(jq -r '.thr_mask // empty | if type=="array" then join(",") else tostring end' config.json)

num_images="${#IMAGES[@]}"

# ---------------------------------------------------------------------------
# Validate required inputs
# ---------------------------------------------------------------------------
if [ "$num_images" -lt 2 ]; then
    echo "Error: at least two images are required in config.json under .images[]" >&2
    exit 1
fi

for img in "${IMAGES[@]}"; do
    if [ -z "$img" ] || [ "$img" = "null" ]; then
        echo "Error: empty image path found in config.json" >&2
        exit 1
    fi

    if [ ! -f "$img" ]; then
        echo "Error: image not found: $img" >&2
        exit 1
    fi
done

echo "Number of images:       $num_images"
echo "Checkerboard tiles:     $tiles"

if [ -n "$thr_mask" ] && [ "$thr_mask" != "null" ]; then
    echo "Threshold mask:         $thr_mask"
else
    echo "Threshold mask:         not set"
fi

# ---------------------------------------------------------------------------
# Prepare output directory
# ---------------------------------------------------------------------------
mkdir -p output

# ---------------------------------------------------------------------------
# Build labels from Brainlife _inputs metadata
# ---------------------------------------------------------------------------
mapfile -t LABELS < <(
    jq -r '
        ._inputs[]? |
        .meta as $m |
        ($m.subject // "unknown") as $sub |
        ($m.session // empty) as $ses |
        if $ses == "" or $ses == null then
            $sub
        else
            "\($sub)_ses-\($ses)"
        end
    ' config.json 2>/dev/null
)

if [ "${#LABELS[@]}" -ne "$num_images" ]; then
    echo "Warning: could not derive labels from config.json _inputs; using filenames." >&2
    LABELS=()
    for img in "${IMAGES[@]}"; do
        base="$(basename "$img")"
        base="${base%.nii.gz}"
        base="${base%.nii}"
        LABELS+=("$base")
    done
fi

echo "Input labels:"
for ((i=0; i<num_images; i++)); do
    echo "  [$i] ${LABELS[$i]} -> ${IMAGES[$i]}"
done

labels_json="output/input_labels.json"

python3 - "${labels_json}" "${IMAGES[@]}" -- "${LABELS[@]}" <<'PY'
import json
import sys

out = sys.argv[1]
args = sys.argv[2:]

sep = args.index("--")
images = args[:sep]
labels = args[sep + 1:]

with open(out, "w") as f:
    json.dump(
        {
            "images": [
                {
                    "index": i,
                    "path": img,
                    "label": labels[i],
                }
                for i, img in enumerate(images)
            ]
        },
        f,
        indent=4,
    )
PY

# ---------------------------------------------------------------------------
# Run pairwise upper-triangular QC
# ---------------------------------------------------------------------------
num_pairs=0

for ((i=0; i<num_images; i++)); do
    for ((j=i+1; j<num_images; j++)); do

        fixed="${IMAGES[$i]}"
        moving="${IMAGES[$j]}"

        pair_dir=$(printf "output/pair_%02d_%02d" "$i" "$j")
        mkdir -p "$pair_dir"

        echo "------------------------------------------------------------"
        echo "Running QC pair ${i} vs ${j}"
        echo "Fixed image:  $fixed"
        echo "Moving image: $moving"
        echo "Fixed label:  ${LABELS[$i]}"
        echo "Moving label: ${LABELS[$j]}"
        echo "Output dir:   $pair_dir"
        echo "------------------------------------------------------------"

        EXTRA_ARGS=""
        if [ -n "$thr_mask" ] && [ "$thr_mask" != "null" ]; then
            EXTRA_ARGS="$EXTRA_ARGS --thr-mask $thr_mask"
        fi

        run_in_env python3 "${SCRIPT_DIR}/registration_qc.py" \
            --fixed "$fixed" \
            --moving "$moving" \
            --outdir "$pair_dir" \
            --checkerboard-tiles "$tiles" \
            $EXTRA_ARGS

        num_pairs=$((num_pairs + 1))
    done
done

echo "Completed $num_pairs pairwise QC comparisons."

# ---------------------------------------------------------------------------
# Build group-level metric matrices
# ---------------------------------------------------------------------------
echo "Building group-level metric matrices ..."

run_in_env python3 "${SCRIPT_DIR}/aggregate_pairwise_qc.py" \
    --config config.json \
    --labels-json "$labels_json" \
    --output-dir output

# ---------------------------------------------------------------------------
# Generate product.json for Brainlife
# ---------------------------------------------------------------------------
echo "Generating product.json ..."

bash "${SCRIPT_DIR}/generate_product_json.sh" --compress output product.json

# ---------------------------------------------------------------------------
# Generate figures/images + figures/images.json
# ---------------------------------------------------------------------------
echo "Generating figures manifest ..."

IMAGE_DIR="output"
OUTPUT_DIR="."

bash "${SCRIPT_DIR}/generate_figures_manifest.sh" "$IMAGE_DIR" "$OUTPUT_DIR"

echo "Multiple registration QC complete."
